{
    "version": 4,
    "include": [
        "CMakeBasePresets.json"
    ],
    "configurePresets": [
        {
            "name": "_unstable_tests_overlay",
            "hidden": true,
            "cacheVariables": {
                "OPENDAQ_SKIP_UNSTABLE_TESTS": false
            }
        },
        {
            "name": "unstable_tests_ci",
            "hidden": false,
            "inherits": [
                "_unstable_tests_overlay",
                "ci"
            ]
        },
        {
            "name": "unstable_tests_ci-legacy-compiler",
            "hidden": true,
            "inherits": [
                "_unstable_tests_overlay",
                "ci-legacy-compiler"
            ]
        },
        {
            "name": "unstable_tests_ci-legacy-compiler-x86",
            "hidden": true,
            "inherits": [
                "_unstable_tests_overlay",
                "ci-legacy-compiler-x86"
            ]
        },
        {
            "name": "unstable_tests_ci-no-bindings",
            "hidden": true,
            "inherits": [
                "_unstable_tests_overlay",
                "ci-no-bindings"
            ]
        }
    ],
    "testPresets": [
        {
            "name": "run_unstable_test_repeatedly",
            "description": "Run only unstable tests multiple times",
            "configurePreset": "unstable_tests_ci",
            "output": {
                "outputOnFailure": true
            },
            "environment": {
                "GTEST_FILTER": "*.UNSTABLE_SKIPPED_*",
                "GTEST_REPEAT": "30"
            },
            "filter": {
                "exclude": {
                    "name": "test_py_opendaq"
                }
            }
        }
    ]
}
