{
    "version": 4,
    "include": [
        "CMakeBasePresets.json"
    ],
    "configurePresets": [
        {
            "name": "unstable_tests_ci",
            "hidden": false,
            "inherits": [
                "ci"
            ],
            "cacheVariables": {
                "OPENDAQ_SKIP_UNSTABLE_TESTS": false
            }
        },
        {
            "name": "unstable_tests_ci-msvc",
            "hidden": true,
            "inherits": [
                "ci-msvc"
            ],
            "cacheVariables": {
                "OPENDAQ_SKIP_UNSTABLE_TESTS": false
            }
        },
        {
            "name": "unstable_tests_ci-macos",
            "hidden": true,
            "inherits": [
                "ci-macos"
            ],
            "cacheVariables": {
                "OPENDAQ_SKIP_UNSTABLE_TESTS": false
            }
        },
        {
            "name": "unstable_tests_ci-legacy-compiler",
            "hidden": true,
            "inherits": [
                "ci-legacy-compiler"
            ],
            "cacheVariables": {
                "OPENDAQ_SKIP_UNSTABLE_TESTS": false
            }
        }
    ],
    "testPresets": [
        {
            "name": "run_unstable_test_repeatedly",
            "description": "Run only unstable tests multiple times",
            "configurePreset": "unstable_tests_ci",
            "output": {
                "outputOnFailure": true
            },
            "environment": {
                "GTEST_FILTER": "*.UNSTABLE_SKIPPED_*",
                "GTEST_REPEAT": "30"
            },
            "filter": {
                "exclude": {
                    "name": "test_py_opendaq"
                }
            }
        }
    ]
}
