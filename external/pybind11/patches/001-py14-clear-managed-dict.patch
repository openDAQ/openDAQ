diff --git a/include/pybind11/detail/class.h b/include/pybind11/detail/class.h
index cd7e87f8..f9258a2e 100644
--- a/include/pybind11/detail/class.h
+++ b/include/pybind11/detail/class.h
@@ -490,6 +490,15 @@ extern "C" inline void pybind11_object_dealloc(PyObject *self) {
         PyObject_GC_UnTrack(self);
     }
 
+#if PY_VERSION_HEX >= 0x030D0000
+    // On Python 3.13+, PyObject_GC_Del no longer implicitly clears the managed
+    // dict. Without this call, objects stored in __dict__ of py::dynamic_attr()
+    // types have their refcounts abandoned, causing permanent memory leaks.
+    if (PyType_HasFeature(type, Py_TPFLAGS_MANAGED_DICT)) {
+        PyObject_ClearManagedDict(self);
+    }
+#endif
+
     clear_instance(self);
 
     type->tp_free(self);
